{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "CPU Core Usage Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$pod\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "title": "Memory Resident Set Size (RSS)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(container_memory_rss{namespace=~\"$namespace\", pod=~\"$pod\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "range": true,
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["microservices", "telemetry"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Standard Microservice Telemetry Template",
  "timezone": "utc",
  "variables": {
    "list": [
      {
        "current": {
          "selected": true,
          "value": "default"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "name": "namespace",
        "query": "label_values(kube_pod_info, namespace)",
        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "value": "All"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Pod",
        "name": "pod",
        "query": "label_values(kube_pod_info{namespace=\"$namespace\"}, pod)",
        "type": "query"
      }
    ]
  }
}
